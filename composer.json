{
  "name": "xmo/mineadmin",
  "type": "project",
  "keywords": [
    "mineadmin",
    "swoole",
    "hyperf"
  ],
  "homepage": "https://www.mineadmin.com/",
  "description": "Quickly build a background management system for web applications",
  "license": "Apache-2.0",
  "require": {
    "php": ">=8.1",
    "ext-gd": "*",
    "ext-json": "*",
    "ext-openssl": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "ext-redis": "*",
    "ext-swoole": ">=4.5",
    "ext-xlswriter": "*",
    "doctrine/dbal": "^3.9.0",
    "easyswoole/verifycode": "^3.1.0",
    "hyperf/amqp": "^3.1.0",
    "hyperf/async-queue": "^3.1.0",
    "hyperf/cache": "^3.1.0",
    "hyperf/command": "^3.1.0",
    "hyperf/config": "^3.1.0",
    "hyperf/crontab": "^3.1.0",
    "hyperf/database": "^3.1.0",
    "hyperf/db-connection": "^3.1.0",
    "hyperf/filesystem": "^3.1.0",
    "hyperf/framework": "^3.1.0",
    "hyperf/guzzle": "^3.1.0",
    "hyperf/http-server": "^3.1.0",
    "hyperf/logger": "^3.1.0",
    "hyperf/memory": "^3.1.0",
    "hyperf/model-cache": "^3.1.0",
    "hyperf/paginator": "^3.1.0",
    "hyperf/pool": "^3.1.0",
    "hyperf/process": "^3.1.0",
    "hyperf/redis": "^3.1.0",
    "hyperf/snowflake": "^3.1.0",
    "hyperf/translation": "^3.1.0",
    "hyperf/validation": "^3.1.0",
    "hyperf/websocket-server": "^3.1.0",
    "limingxinleo/easywechat-classmap": "^1.0",
    "overtrue/easy-sms": "^2.5.0",
    "overtrue/flysystem-qiniu": "^3.2.0",
    "phpoffice/phpspreadsheet": "^1.29.0",
    "symfony/property-access": "^6.3.0",
    "symfony/serializer": "^6.4.0",
    "tangwei/apidocs": "^v3.0.7",
    "w7corp/easywechat": "^6.17.0",
    "xmo/jwt-auth": "0.6.0",
    "yansongda/hyperf-pay": "^1.7.0",
    "yurunsoft/phpmailer-swoole": "^1.0.0",
    "zoujingli/ip2region": "^1.0.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "friendsofphp/php-cs-fixer": "^3.38.0",
    "hyperf/devtool": "^3.1.0",
    "hyperf/testing": "^3.1.0",
    "hyperf/watcher": "^3.1.0",
    "mockery/mockery": "^1.6.0",
    "phpstan/phpstan": "^1.10.0",
    "swoole/ide-helper": "^4.8.0"
  },
  "suggest": {
    "ext-openssl": "Required to use HTTPS.",
    "ext-json": "Required to use JSON.",
    "ext-pdo": "Required to use MySQL Client.",
    "ext-pdo_mysql": "Required to use MySQL Client.",
    "ext-redis": "Required to use Redis Client."
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Mine\\": "mine/",
      "Api\\": "api/"
    },
    "files": [
      "mine/Helper/functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "HyperfTest\\": "./test/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "composer/package-versions-deprecated": true
    }
  },
  "extra": [],
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-autoload-dump": [
      "rm -rf runtime/container"
    ],
    "test": "co-phpunit --prepend test/bootstrap.php -c phpunit.xml --colors=always",
    "cs-fix": "php-cs-fixer fix $1 --config=./.php-cs-fixer",
    "analyse": "phpstan analyse --memory-limit 300M -l 0 -c phpstan.neon ./app ./config ./mine",
    "gen-model": "@php bin/hyperf.php mine:model-gen --module=模块名 --table=表名称",
    "start": [
      "Composer\\Config::disableProcessTimeout",
      "php ./bin/hyperf.php start"
    ]
  }
}
