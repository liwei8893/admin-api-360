{
  "name": "xmo/mineadmin",
  "type": "project",
  "keywords": [
    "mineadmin",
    "swoole",
    "hyperf"
  ],
  "homepage": "https://www.mineadmin.com/",
  "description": "Quickly build a background management system for web applications",
  "license": "Apache-2.0",
  "require": {
    "php": ">=8.1",
    "ext-gd": "*",
    "ext-json": "*",
    "ext-openssl": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "ext-redis": "*",
    "ext-swoole": ">=4.5",
    "ext-xlswriter": "*",
    "doctrine/dbal": "^3.7.1",
    "easyswoole/verifycode": "^3.1.2",
    "hyperf/amqp": "~3.0.42",
    "hyperf/async-queue": "~3.0.37",
    "hyperf/cache": "~3.0.37",
    "hyperf/command": "~3.0.41",
    "hyperf/config": "~3.0.37",
    "hyperf/crontab": "~3.0.42",
    "hyperf/database": "~3.0.42",
    "hyperf/db-connection": "~3.0.37",
    "hyperf/filesystem": "~3.0.37",
    "hyperf/framework": "~3.0.37",
    "hyperf/guzzle": "~3.0.37",
    "hyperf/http-server": "~3.0.41",
    "hyperf/logger": "~3.0.37",
    "hyperf/memory": "~3.0.37",
    "hyperf/model-cache": "~3.0.37",
    "hyperf/paginator": "~3.0.37",
    "hyperf/pool": "~3.0.37",
    "hyperf/process": "~3.0.37",
    "hyperf/redis": "~3.0.40",
    "hyperf/snowflake": "~3.0.37",
    "hyperf/translation": "~3.0.42",
    "hyperf/validation": "~3.0.41",
    "hyperf/websocket-server": "~3.0.37",
    "overtrue/easy-sms": "^2.5.0",
    "overtrue/flysystem-qiniu": "^3.2.2",
    "pengxuxu/hyperf-easywechat6": "^1.0.4",
    "phpoffice/phpspreadsheet": "^1.29.0",
    "symfony/property-access": "^6.3.2",
    "tangwei/apidocs": "^2.1.12",
    "w7corp/easywechat": "^6.12.11",
    "xmo/jwt-auth": "0.6.0",
    "yansongda/pay": "~3.2.14",
    "yurunsoft/phpmailer-swoole": "^1.0.2",
    "zoujingli/ip2region": "^1.0.13"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.37.1",
    "hyperf/devtool": "3.0.16",
    "hyperf/testing": "3.0.16",
    "hyperf/watcher": "3.0.16",
    "mockery/mockery": "^1.6.6",
    "phpstan/phpstan": "^1.10.41",
    "swoole/ide-helper": "^4.8.13"
  },
  "suggest": {
    "ext-openssl": "Required to use HTTPS.",
    "ext-json": "Required to use JSON.",
    "ext-pdo": "Required to use MySQL Client.",
    "ext-pdo_mysql": "Required to use MySQL Client.",
    "ext-redis": "Required to use Redis Client."
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Mine\\": "mine/",
      "Api\\": "api/"
    },
    "files": [
      "mine/Helper/functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "HyperfTest\\": "./test/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "composer/package-versions-deprecated": true
    }
  },
  "extra": [],
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-autoload-dump": [
      "rm -rf runtime/container"
    ],
    "test": "co-phpunit --prepend test/bootstrap.php -c phpunit.xml --colors=always",
    "cs-fix": "php-cs-fixer fix $1 --config=./.php-cs-fixer",
    "analyse": "phpstan analyse --memory-limit 300M -l 0 -c phpstan.neon ./app ./config ./mine",
    "start": [
      "Composer\\Config::disableProcessTimeout",
      "php ./bin/hyperf.php start"
    ]
  },
  "repositories": {
    "packagist": {
      "type": "composer",
      "url": "https://mirrors.tencent.com/composer/"
    }
  }
}
