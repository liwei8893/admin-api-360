
/**
 * {BUSINESS_NAME}导入
 * @returns
 */
export const importExcel = (data = {}) => request.post({
  url: '{REQUEST_ROUTE}/import',
  data,
})

/**
 * {BUSINESS_NAME}下载模板
 * @returns
 */
export const downloadTemplate = () => request.post({
  url: '{REQUEST_ROUTE}/downloadTemplate',
  responseType: 'blob',
})
