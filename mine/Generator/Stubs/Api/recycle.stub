
/**
 * 从回收站获取{BUSINESS_NAME}数据列表
 */
export function getRecycleList(params?: Recordable) {
  return useHttp.Get<ResOptions<BasicFetchResult<Recordable>>>('{REQUEST_ROUTE}/recycle', { params })
}

/**
 * 恢复{BUSINESS_NAME}数据
 */
export function recoverys(data?: Recordable) {
  return useHttp.Put<Recordable>('{REQUEST_ROUTE}/recovery', data)
}

/**
 * 真实删除{BUSINESS_NAME}
 */
export function realDeletes(data?: Recordable) {
  return useHttp.Delete<ResOptions>('{REQUEST_ROUTE}/realDelete', data)
}
